<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F4F6"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#7B31FB"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Nombre:" android:textSize="10sp" android:textColor="#D1C4E9" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Villegas Rodriguez\nJose Julian" android:textColor="#FFFFFF"
                android:textStyle="bold" android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Edad:" android:textSize="10sp" android:textColor="#D1C4E9" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="22" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:gravity="end">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Correo:" android:textSize="10sp" android:textColor="#D1C4E9" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="julianvillegas191\n@gmail.com" android:textAlignment="viewEnd"
                android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <EditText android:id="@+id/txtNombre" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Nombre completo" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="8dp" />

    <EditText android:id="@+id/txtEdad" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Edad" android:inputType="number" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="8dp" />

    <EditText android:id="@+id/txtCorreo" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Correo electrónico" android:inputType="textEmailAddress" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="16dp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/btnNuevo" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:text="NUEVO" android:backgroundTint="#3F51B5" android:layout_marginEnd="2dp"/>

        <Button android:id="@+id/btnGrabar" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:text="GUARDAR" android:backgroundTint="#3F51B5" android:layout_marginEnd="2dp"/>

        <Button android:id="@+id/btnLectura" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="EDITAR" android:backgroundTint="#3F51B5" android:layout_marginEnd="2dp"/>

        <Button android:id="@+id/btnEliminar" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:text="BORRAR" android:backgroundTint="#D32F2F" />
    </LinearLayout>

    <GridView
        android:id="@+id/lvDatos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp"
        android:numColumns="3"
        android:horizontalSpacing="2dp"
        android:verticalSpacing="2dp"
        android:background="#E0E0E0"
        android:stretchMode="columnWidth" />

</LinearLayout>